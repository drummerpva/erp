{
  "name": "erp-refatorado",
  "version": "0.6.0",
  "description": "",
  "main": "src/main.ts",
  "scripts": {
    "build": "tsup --tsconfig tsconfig.build.json src/main.ts",
    "start": "node dist/main.cjs",
    "dev": "tsx watch --env-file .env.dev src/main.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "prepare": "husky",
    "lint:fix": "eslint src/*.ts --fix",
    "db:migrate": "node --env-file=.env.dev ./node_modules/knex/bin/cli.js migrate:latest",
    "db:rollback": "node --env-file=.env.dev ./node_modules/knex/bin/cli.js migrate:rollback"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@rocketseat/eslint-config": "^2.2.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "24",
    "@types/sinon": "^21.0.1",
    "axios": "^1.17.0",
    "eslint": "^8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "git-commit-msg-linter": "^5.0.8",
    "husky": "^9.1.7",
    "knex": "^3.2.10",
    "lint-staged": "^17.0.6",
    "mysql2": "^3.22.5",
    "sinon": "^22.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.ts": [
      "npm run lint:fix"
    ]
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1"
  }
}
